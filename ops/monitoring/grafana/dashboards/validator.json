      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Vote Credits",
      "targets": [
        {
          "expr": "rate(solana_validator_vote_credits_total[5m]) * 300",
          "legendFormat": "Credits / 5m"
        },
        {
          "expr": "increase(solana_validator_vote_credits_total[1h])",
          "legendFormat": "Credits / 1h"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
