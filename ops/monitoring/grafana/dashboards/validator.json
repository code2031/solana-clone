            "lineWidth": 2,
            "fillOpacity": 15,
            "pointSize": 5,
            "showPoints": "never"
          },
          "unit": "none"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Slot Height Over Time",
      "targets": [
        {
          "expr": "solana_validator_slot_height",
          "legendFormat": "Validator Slot"
        },
        {
          "expr": "solana_cluster_slot_height",
          "legendFormat": "Cluster Slot"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15
          },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Transactions Per Second (TPS)",
      "targets": [
        {
          "expr": "rate(solana_validator_transactions_total[1m])",
          "legendFormat": "TPS (1m avg)"
        },
        {
          "expr": "rate(solana_validator_transactions_total[5m])",
          "legendFormat": "TPS (5m avg)"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "id": 12,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Skip Rate",
      "targets": [
        {
          "expr": "rate(solana_validator_skipped_slots_total[10m]) / clamp_min(rate(solana_validator_leader_slots_total[10m]), 1)",
          "legendFormat": "Skip Rate (10m)"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "unit": "none"
        }
      },
